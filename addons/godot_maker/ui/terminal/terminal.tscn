[ext_resource type="Texture2D" path="res://addons/godot_maker/icons/ui/x.svg" id="4"]

[node name="Terminal" type="VBoxContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 0
