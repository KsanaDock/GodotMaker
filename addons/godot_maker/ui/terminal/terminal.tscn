icon = ExtResource("3")
flat = true
icon_alignment = 1

[node name="KillBtn" type="Button" parent="TopBar/HBox/Actions"]
unique_name_in_owner = true
custom_minimum_size = Vector2(28, 28)
layout_mode = 2
