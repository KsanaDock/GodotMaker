[node name="Actions" type="HBoxContainer" parent="TopBar/HBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="AddBtn" type="Button" parent="TopBar/HBox/Actions"]
unique_name_in_owner = true
