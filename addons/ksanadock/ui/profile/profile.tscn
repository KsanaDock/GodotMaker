[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_Avatar"]
bg_color = Color(0.024, 0.373, 0.275, 1)
corner_radius_top_left = 10
corner_radius_top_right = 10
corner_radius_bottom_left = 10
corner_radius_bottom_right = 10

[sub_resource type="Shader" id="Shader_Avatar"]
code = "shader_type canvas_item;
uniform float radius_scale = 0.1; // 圆角大小占整体的百分比
void fragment() {
    vec2 half_size = vec2(0.5);
    vec2 d = abs(UV - half_size) - half_size + vec2(radius_scale);
    float dist = length(max(d, vec2(0.0))) + min(max(d.x, d.y), 0.0) - radius_scale;
    if (dist > 0.001) {
        COLOR.a = 0.0;
    }
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_Avatar"]
shader = SubResource("Shader_Avatar")

