[node name="LoginPanel" type="Window"]
title = "KsanaDock — Sign In"
size = Vector2i(420, 580)
unresizable = true
script = ExtResource("1_script")

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_bg")

[node name="Margin" type="MarginContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/margin_top = 32
theme_override_constants/margin_bottom = 32
theme_override_constants/margin_left = 40
theme_override_constants/margin_right = 40

[node name="VBox" type="VBoxContainer" parent="Panel/Margin"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 14

[node name="LogoRect" type="TextureRect" parent="Panel/Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(64, 64)
size_flags_horizontal = 4
size_flags_vertical = 4
expand_mode = 1
stretch_mode = 5

[node name="TitleLabel" type="Label" parent="Panel/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 24
text = "Welcome to KsanaDock"
horizontal_alignment = 1

[node name="SubtitleLabel" type="Label" parent="Panel/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.322, 0.322, 0.357, 1)
theme_override_font_sizes/font_size = 13
text = "Sign in to continue"
horizontal_alignment = 1

[node name="Spacer1" type="Control" parent="Panel/Margin/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 8)

[node name="ErrorLabel" type="RichTextLabel" parent="Panel/Margin/VBox"]
unique_name_in_owner = true
visible = false
layout_mode = 2
theme_override_colors/default_color = Color(0.937, 0.267, 0.267, 1)
theme_override_font_sizes/normal_font_size = 12
bbcode_enabled = true
text = "[img=14]res://addons/ksanadock/icons/ui/triangle-alert.svg[/img] Incorrect email or password"
fit_content = true

[node name="EmailLabel" type="Label" parent="Panel/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.322, 0.322, 0.357, 1)
theme_override_font_sizes/font_size = 10
text = "EMAIL"

[node name="EmailInput" type="LineEdit" parent="Panel/Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 36)
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_placeholder_color = Color(0.322, 0.322, 0.357, 1)
theme_override_styles/normal = SubResource("StyleBoxFlat_input_normal")
placeholder_text = "name@example.com"

[node name="PasswordLabel" type="Label" parent="Panel/Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.322, 0.322, 0.357, 1)
theme_override_font_sizes/font_size = 10
text = "PASSWORD"

[node name="PasswordInput" type="LineEdit" parent="Panel/Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(0, 36)
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_placeholder_color = Color(0.322, 0.322, 0.357, 1)
theme_override_styles/normal = SubResource("StyleBoxFlat_input_normal")
