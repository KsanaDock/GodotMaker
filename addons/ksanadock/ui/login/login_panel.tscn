secret = true

[node name="Spacer2" type="Control" parent="Panel/Margin/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 4)

[node name="LoginButton" type="Button" parent="Panel/Margin/VBox"]
unique_name_in_owner = true
