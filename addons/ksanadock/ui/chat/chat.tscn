[gd_scene load_steps=8 format=3]

[ext_resource type="Script" path="res://addons/ksanadock/ui/chat/chat.gd" id="1"]
[ext_resource type="Texture2D" path="res://addons/ksanadock/icons/ui/film.svg" id="2"]
[ext_resource type="Texture2D" path="res://addons/ksanadock/icons/ui/x.svg" id="3"]
