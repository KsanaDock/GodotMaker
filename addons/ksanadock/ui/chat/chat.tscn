theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 6

[node name="VBox" type="VBoxContainer" parent="InputBG/Margin"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="CtxBar" type="HBoxContainer" parent="InputBG/Margin/VBox"]
